# ── Python / Cache (Exclude everywhere) ──────────────────────────────────
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
**/*.so
**/*.egg
**/*.egg-info/
**/*.whl

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env_*
.venv_*/
**/node_modules/

# ── Distribution / Build ─────────────────────────────────────────────────────
dist/
build/
.eggs/
MANIFEST

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
!.env.sample

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Testing / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
*.lcov

# ── Logs / temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
/tmp/

# ── OMC (oh-my-claudecode) state ──────────────────────────────────────────────
.omc/

# ── Project-specific ─────────────────────────────────────────────────────────
# Keep outputs/ tracked (comparison results)
# Keep ontology/ tracked (schema files)
# Keep datasets/ tracked (benchmark annotations)

# Ignore large model weights or downloaded assets inside baselines
baselines/*/models/
baselines/*/checkpoints/
baselines/*/*.bin
baselines/*/*.pt
baselines/*/*.onnx

# Input scratch files
analyzer/input/*
!analyzer/input/.gitkeep
analyzer/mcp/.gitkeep

# ==============================================================================
# LADDER Baselines (NER & RE) Large Files
# ==============================================================================

# 1. Virtual Environments (PyTorch DLLs, etc.)
baselines/ladder/ner/venv_ner/
baselines/ladder/ner/.venv_ladder_ner/
baselines/ladder/relation_extraction/venv_re/
baselines/ladder/relation_extraction/.venv_ladder_re/

# 2. Models & Checkpoints
baselines/ladder/relation_extraction/*.pt
baselines/ladder/relation_extraction/*.bin
baselines/ladder/ner/CyNER_src/models/

# 3. Python Cache & Logs
baselines/ladder/**/__pycache__/
baselines/ladder/**/*.pyc
baselines/ladder/relation_extraction/*.log

# 4. Outputs (Temporary/Outputs)
baselines/ladder/ner/sample_output.txt
baselines/ladder/relation_extraction/*_test_predictions.json
