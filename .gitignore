# ── Python / Cache (Exclude everywhere) ──────────────────────────────────
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
**/*.so
**/*.egg
**/*.egg-info/
**/*.whl

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env_*
.venv_*/
**/node_modules/

# ── Distribution / Build ─────────────────────────────────────────────────────
dist/
build/
.eggs/
MANIFEST

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
!.env.sample

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Testing / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
*.lcov

# ── Logs / temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
/tmp/

# ── OMC (oh-my-claudecode) state ──────────────────────────────────────────────
.omc/

# ── Project-specific ─────────────────────────────────────────────────────────
# Keep outputs/ tracked (comparison results)
# Keep ontology/ tracked (schema files)
# Keep datasets/ tracked (benchmark annotations)
outputs/*

# Ignore large model weights or downloaded assets inside baselines
baselines/*/models/
baselines/*/checkpoints/
baselines/*/*.bin
baselines/*/*.pt
baselines/*/*.onnx

# Input scratch files
analyzer/input/*
!analyzer/input/.gitkeep
analyzer/mcp/.gitkeep

# Watson-new
watson-new/run*
**/*.pkl
**/chroma.sqlite3
