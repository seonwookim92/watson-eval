# LLM Provider: 'openai' or 'ollama'
LLM_PROVIDER=openai

# OpenAI Settings (if using openai)
OPENAI_API_KEY=sk-proj-
OPENAI_MODEL=gpt-5-mini

# Ollama Settings (if using ollama)
OLLAMA_BASE_URL=http://192.168.123.112:11434
OLLAMA_MODEL=qwen3-coder-next:q8_0
OLLAMA_NUM_CTX=65535

# Directory Settings (Optional, defaults are usually fine)
# ONTOLOGY_DIR=ontology/uco
# MCP_SERVER_PATH=mcp/universal-ontology-mcp/main.py

# ── Evaluation Settings ────────────────────────────────────────────────────
# Matching mode for eval.py:
#   jaccard   – fast word-token overlap (no extra deps, default)
#   embedding – cosine similarity via sentence-transformers (semantic, fast)
#   llm       – LLM batch judgment per sample (most accurate, uses EVAL_LLM_*)
EVAL_MATCH_MODE=embedding

# Embedding similarity threshold (used when EVAL_MATCH_MODE=embedding)
# Range: 0.0–1.0  |  Recommended: 0.70–0.80
# EVAL_EMBEDDING_THRESHOLD=0.75

# LLM used for evaluation (EVAL_MATCH_MODE=llm)
# Can be a local model to save cost while using an Enterprise LLM for prediction.
EVAL_LLM_PROVIDER=ollama
EVAL_LLM_MODEL=qwen3-coder-next:q8_0
EVAL_LLM_BASE_URL=http://192.168.123.112:11434
# To use OpenAI as eval LLM instead:
# EVAL_LLM_PROVIDER=openai
# EVAL_LLM_MODEL=gpt-5-mini
