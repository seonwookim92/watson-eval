# =============================================================================
# Unified Configuration for CTI Ontology Evaluation (Watson & Baselines)
#
# 1) 아래 두 블록 중 하나만 활성화하고 나머지는 주석 처리하세요.
# 2) watson-new / evaluate 스크립트는 OPENAI_* 값을 자동으로 상속합니다.
# =============================================================================

# ── Mode A: vLLM (로컬 OpenAI-compatible 서버) ────────────────────────────────
LLM_PROVIDER=openai
OPENAI_BASE_URL=http://192.168.100.2:8081/v1
OPENAI_MODEL=qwen3.5-35b
OPENAI_API_KEY=dummy

# ── Mode B: OpenAI API ────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# =============================================================================
# Evaluation Settings
# =============================================================================

EVAL_MATCH_MODE=embedding

# =============================================================================
# watson-new: LLM은 위 OPENAI_* 값을 자동 상속
#             아래는 LLM과 별개인 임베딩 서버 설정
# =============================================================================

WATSON_NEW_LLM_THINKING=false

# ── Mode A: 원격 임베딩 서버 (vLLM과 함께 사용) ──────────────────────────────
WATSON_NEW_EMBEDDING_MODE=remote
WATSON_NEW_EMBEDDING_BASE_URL=http://192.168.100.2:8082/v1
WATSON_NEW_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
WATSON_NEW_EMBEDDING_API_KEY=

# ── Mode B: OpenAI 임베딩 ──────────────────────────────────────────────────────
# WATSON_NEW_EMBEDDING_MODE=remote
# WATSON_NEW_EMBEDDING_BASE_URL=https://api.openai.com/v1
# WATSON_NEW_EMBEDDING_MODEL=text-embedding-3-small
# WATSON_NEW_EMBEDDING_API_KEY=sk-...

# ── watson-new MCP 전용 override (비워두면 watson-new LLM / embedding 설정 상속) ──
# WATSON_NEW_MCP_LLM_BASE_URL=http://192.168.100.2:8081/v1
# WATSON_NEW_MCP_LLM_MODEL=qwen3.5-35b
# WATSON_NEW_MCP_LLM_API_KEY=dummy
# WATSON_NEW_MCP_EMBEDDING_MODE=remote
# WATSON_NEW_MCP_EMBEDDING_BASE_URL=http://192.168.100.2:8082/v1
# WATSON_NEW_MCP_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# WATSON_NEW_MCP_EMBEDDING_API_KEY=

# ── Evaluation embedding override (비워두면 watson-new embedding 설정 상속) ──
# EVAL_EMBEDDING_MODE=remote
# EVAL_EMBEDDING_BASE_URL=http://192.168.100.2:8082/v1
# EVAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EVAL_EMBEDDING_API_KEY=
