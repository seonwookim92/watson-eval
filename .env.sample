# =============================================================================
# Unified Configuration for CTI Ontology Evaluation (Watson & Baselines)
# =============================================================================

# Default LLM Provider: 'openai' (vLLM is OpenAI-compatible)
LLM_PROVIDER=openai

# --- OpenAI / vLLM Settings ---
# vLLM exposes an OpenAI-compatible API; point base URL here.
OPENAI_API_KEY=dummy
OPENAI_MODEL=qwen3.5-35b
OPENAI_BASE_URL=http://192.168.123.112:8081/v1

# --- Gemini (Google) Settings ---
GOOGLE_API_KEY=AIza...
GOOGLE_MODEL=gemini-3-flash

# --- Claude (Anthropic) Settings ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-4-6-sonnet

# --- Ollama Settings (disabled; kept for reference) ---
# OLLAMA_BASE_URL=http://192.168.123.112:11434
# OLLAMA_MODEL=qwen3.5:122b
# OLLAMA_NUM_CTX=65536

# --- Evaluation Settings ---
# Matching mode for evaluation: jaccard | embedding | llm
EVAL_MATCH_MODE=embedding
EVAL_EMBEDDING_THRESHOLD=0.6

# LLM used specifically for evaluation matching (EVAL_MATCH_MODE=llm)
EVAL_LLM_PROVIDER=openai
EVAL_LLM_MODEL=qwen3.5-35b
EVAL_LLM_BASE_URL=http://192.168.123.112:8081/v1

# --- CTINexus (LiteLLM) custom endpoint override ---
# LiteLLM picks this up via get_litellm_endpoint_overrides() in llm_processor.py
CUSTOM_BASE_URL=http://192.168.123.112:8081/v1
CUSTOM_API_KEY=dummy

# --- watson-new (OntologyExtractor backend) Settings ---
# Qwen3 thinking mode: false=off (default, faster), true=on (slower, better reasoning)
WATSON_NEW_LLM_THINKING=false

# [vLLM] Uncomment to use local vLLM server
# WATSON_NEW_LLM_BASE_URL=http://192.168.123.112:8081/v1
# WATSON_NEW_LLM_MODEL=qwen3.5-35b
# WATSON_NEW_LLM_API_KEY=dummy
# WATSON_NEW_EMBEDDING_BASE_URL=http://192.168.123.112:8082/v1
# WATSON_NEW_EMBEDDING_MODEL=nomic-embed-text
# WATSON_NEW_EMBEDDING_API_KEY=

# [OpenAI] Uncomment to use OpenAI API
WATSON_NEW_LLM_BASE_URL=https://api.openai.com/v1
WATSON_NEW_LLM_MODEL=gpt-4o
WATSON_NEW_LLM_API_KEY=sk-...
WATSON_NEW_EMBEDDING_MODE=remote
WATSON_NEW_EMBEDDING_BASE_URL=https://api.openai.com/v1
WATSON_NEW_EMBEDDING_MODEL=text-embedding-3-small
WATSON_NEW_EMBEDDING_API_KEY=sk-...
